# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# AI provider - this project uses Google's Gemini API by default because it
# has a genuinely free tier (no credit card, no expiry) for the Flash /
# Flash-Lite models. Get a key in ~30 seconds at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# Extraction tuning - keep batch size and concurrency modest to stay
# comfortably inside the free tier's requests-per-minute limit.
AI_BATCH_SIZE=25
AI_MAX_RETRIES=2
